# Qdrant Cloud
QDRANT_URL=https://YOUR-CLUSTER.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=quran_verses

# HuggingFace Inference API (Read token is enough)
HF_TOKEN=hf_your_token_here

# Vercel KV (auto-populated by `vercel link` after creating a KV store; not needed for local-only dev)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# KV_REST_API_READ_ONLY_TOKEN=
