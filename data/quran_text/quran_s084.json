","حقق","ربب"],"tokens_ordered":["واذنت","لربها","وحقت"],"vec_preview":[-0.044599998742341995,0.07620000094175339,-0.045099999755620956,0.03400000184774399,0.012500000186264515,-0.09019999951124191,-0.02290000021457672,0.05900000035762787]},{"ayah_id":"84:6","surah":84,"ayah":6,"arabic":"يَا أَيُّهَا الْإِنسَانُ إِنَّكَ كَادِحٌ إِلَىٰ رَبِّكَ كَدْحًا فَمُلَاقِيهِ","english":"O man! You sustain rigours to reach your Lord. Ultimately, you will meet Him.","roots_ordered":["انس","الي","ربب","كدح","لقي"],"tokens_ordered":["يا","ايها","الانسان","انك","كادح","ربك","كدحا","فملاقيه"],"vec_preview":[0.015399999916553497,0.06920000165700912,-0.05139999836683273,0.02969999983906746,0.00559999980032444,0.00279999990016222,-0.02590000070631504,0.08429999649524689]},{"ayah_id":"84:7","surah":84,"ayah":7,"arabic":"فَأَمَّا مَنْ أُوتِيَ كِتَابَهُ بِيَمِينِهِ","english":"So as for him who will be given his record in his right hand,","roots_ordered":["اما","كتب","يمن"],"tokens_ordered":["فاما","اوتي","كتابه","بيمينه"],"vec_preview":[-0.009999999776482582,0.0007999999797903001,-0.02160000056028366,-0.003700000001117587,0.002300000051036477,-0.05270000174641609,-0.026200000196695328,0.13580000400543213]},{"ayah_id":"84:8","surah":84,"ayah":8,"arabic":"فَسَوْفَ يُحَاسَبُ حِسَابًا يَسِيرًا","english":"He will soon be given an easy reckoning,","roots_ordered":["حسب","يسر"],"tokens_ordered":["فسوف","يحاسب","حسابا","يسيرا"],"vec_preview":[-0.06880000233650208,0.0003000000142492354,0.014700000174343586,-0.016599999740719795,0.0142000000923872,-0.10689999908208847,-0.07150000333786011,0.011099999770522118]},{"ayah_id":"84:9","surah":84,"ayah":9,"arabic":"وَيَنقَلِبُ إِلَىٰ أَهْلِهِ مَسْرُورًا","english":"And will return to his family rejoicing.","roots_ordered":["اهل","الي","سرر","قلب"],"tokens_ordered":["وينقلب","اهله","مسرورا"],"vec_preview":[-0.03290000185370445,0.0803999975323677,-0.05790000036358833,-0.00039999998989515007,0.022099999710917473,-0.11209999769926071,-0.016499999910593033,0.