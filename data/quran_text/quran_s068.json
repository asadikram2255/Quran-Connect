,"roots_ordered":["يوم","كشف","عن","سوق","دعو","الي","سجد","لا","طوع"],"tokens_ordered":["يوم","يكشف","ساق","ويدعون","السجود","فلا","يستطيعون"],"vec_preview":[-9.999999747378752e-05,0.08410000056028366,-0.05310000106692314,0.05739999935030937,0.0038999998942017555,-0.05909999832510948,-0.05090000107884407,0.08500000089406967]},{"ayah_id":"68:43","surah":68,"ayah":43,"arabic":"خَاشِعَةً أَبْصَارُهُمْ تَرْهَقُهُمْ ذِلَّةٌ ۖ وَقَدْ كَانُوا يُدْعَوْنَ إِلَى السُّجُودِ وَهُمْ سَالِمُونَ","english":"Their eyes will be cast down (with terror and shame) and disgrace will be spreading over them, whereas they were called to prostrate themselves (in the world also) when they were healthy (but they, even then, refused to fall prostrate).","roots_ordered":["خشع","بصر","رهق","ذلل","قد","كون","دعو","الي","سجد","هم","سلم"],"tokens_ordered":["خاشعة","ابصارهم","ترهقهم","ذلة","وقد","كانوا","يدعون","السجود","وهم","سالمون"],"vec_preview":[-0.03060000017285347,0.10830000042915344,-0.0560000017285347,0.08299999684095383,0.05339999869465828,-0.11259999871253967,-0.09139999747276306,0.05339999869465828]},{"ayah_id":"68:44","surah":68,"ayah":44,"arabic":"فَذَرْنِي وَمَن يُكَذِّبُ بِهَـٰذَا الْحَدِيثِ ۖ سَنَسْتَدْرِجُهُم مِّنْ حَيْثُ لَا يَعْلَمُونَ","english":"So, (O Esteemed Beloved,) leave Me (to exact revenge) from the one who rejects this Revelation. Now We shall take them (towards disaster) so gradually that they will not perceive it.","roots_ordered":["وذر","من","كذب","هاذ","حدث","درج","حيث","لا","علم"],"tokens_ordered":["فذرني","ومن","يكذب","بهذا","الحديث","سنستدرجهم","حيث","يعلمون"],"vec_preview":[-0.008100000210106373,0.09399999678134918,0.005100000184029341,0.057999998331069946,0.044199999421834946,0.0024999999441206455,-0.06360000371932983,0.09849999845027924]},{"ayah_id":"68:45","surah":68,"ayah":45,"arabic":"وَأُمْلِي لَهُمْ ۚ إِنَّ كَيْدِي مَتِينٌ","english":"And I am giving them respite. Surely, My strategy is unbeatable.","roots_ordered":["ملو","ل","انن","كيد","متن"],"tokens_ordered":["واملي","لهم","كيدي","متين"],"vec_preview":[-0.05829999968409538,0.05770000070333481,-0.005900000222027302,0.030300000682473183,0.06210000067949295,-0.04989999905228615,-0.020800000056624413,0.13050000369548798]},{"ayah_id":"68:46","surah":68,"ayah":46,"arabic":"أَمْ تَسْأَلُهُمْ أَجْرًا فَهُم مِّن مَّغْرَمٍ مُّثْقَلُونَ","english":"Do you ask them for any reward (for preaching the faith in Messengership) that they are weighed down with (the burden of) paying the recompense?","roots_ordered":["ام","سال","اجر","هم","من","غرم","ثقل"],"tokens_ordered":["ام","تسالهم","اجرا","فهم","مغرم","مثقلون"],"vec_preview":[-0.009100000374019146,0.029999999329447746,-0.038600001484155655,-0.021199999377131462,0.04170000180602074,-0.03889999911189079,0.0024999999441206455,0.04639999940991402]},{"ayah_id":"68:47","surah":68,"ayah":47,"arabic":"أَمْ عِندَهُمُ الْغَيْبُ فَهُمْ يَكْتُبُونَ","english":"Do they have the knowledge of the unseen that they write down (their judgments on the basis of that)?","roots_ordered":["ام","عند","غيب","هم","كتب"],"tokens_ordered":["ام","عندهم","الغيب","فهم","يكتبون"],"vec_preview":[-0.0835999995470047,-0.006599999964237213,-0.01640000008046627,0.018200000748038292,-0.0478999987244606,-0.006000000052154064,-0.011599999852478504,0.13609999418258667]},{"ayah_id":"68:48","surah":68,"ayah":48,"arabic":"فَاصْبِرْ لِحُكْمِ رَبِّكَ وَلَا تَكُن كَصَاحِبِ الْحُوتِ إِذْ نَادَىٰ وَهُوَ مَكْظُومٌ","english":"So be steadfast in waiting for the command of your Lord, and do not (take it to your heart) like (Yunus [Jonah], the Messenger with) fish episode, when he cried out (to Allah) in a state pent up with rage and grief (against his community).","roots_ordered":["صبر","حكم","ربب","لا","كون","صحب","حوت","اذ","ندي","هو","كظم"],"tokens_ordered":["فاصبر","لحكم","ربك","ولا","تكن","كصاحب","الحوت","نادي","وهو","مكظوم"],"vec_preview":[-0.02850000001490116,0.10490000247955322,-0.02419999986886978,0.027400000020861626,0.032999999821186066,-0.11069999635219574,-0.01730000041425228,0.08699999749660492]},{"ayah_id":"68:49","surah":68,"ayah":49,"arabic":"لَّوْلَا أَن تَدَارَكَهُ نِعْمَةٌ مِّن رَّبِّهِ لَنُبِذَ بِالْعَرَاءِ وَهُوَ مَذْمُومٌ","english":"Had the mercy and blessing of his Lord not helped him, he would certainly have been thrown in the barren field, blamed. (But Allah saved him from that.)","roots_ordered":["لولا","ان","درك","نعم","من","ربب","نبذ","عري","هو","ذمم"],"tokens_ordered":["لولا","تداركه","نعمة","ربه","لنبذ","بالعراء","وهو","مذموم"],"vec_preview":[-0.022600000724196434,0.08160000294446945,-0.09610000252723694,-0.020800000056624413,0.01889999955892563,-0.03739999979734421,-0.06199999898672104,0.11640000343322754]},{"ayah_id":"68:50","surah":68,"ayah":50,"arabic":"فَاجْتَبَاهُ رَبُّهُ فَجَعَلَهُ مِنَ الصَّالِحِينَ","english":"Then his Lord exalted him and (placed him) amongst the perfectly pious (blessing him with His exceptional nearness).","roots_ordered":["جبي","ربب","جعل","من","صلح"],"tokens_ordered":["فاجتباه","ربه","فجعله","الصالحين"],"vec_preview":[-0.04610000178217888,0.023499999195337296,-0.09830000251531601,-0.02070000022649765,0.03449999913573265,-0.056299999356269836,-0.08810000121593475,0.05249999836087227]},{"ayah_id":"68:51","surah":68,"ayah":51,"arabic":"وَإِن يَكَادُ الَّذِينَ كَفَرُوا لَيُزْلِقُونَكَ بِأَبْصَارِهِمْ لَمَّا سَمِعُوا الذِّكْرَ وَيَقُولُونَ إِنَّهُ لَمَجْنُونٌ","english":"And indeed, when the disbelievers listen to the Qur’an, it seems as if they wish to damage you with their (jealously evil) looks and say: ‘He is insane.’","roots_ordered":["ان","كود","اللذ","كفر","زلق","بصر","لمما","سمع","ذكر","قول","انن","جنن"],"tokens_ordered":["وان","يكاد","الذين","كفروا","ليزلقونك","بابصارهم","سمعوا","الذكر","ويقولون","لمجنون"],"vec_preview":[-0.005200000014156103,0.08879999816417694,-0.04820000007748604,0.0868000015616417,0.05389999970793724,-0.04360000044107437,-0.025299999862909317,0.1363999992609024]},{"ayah_id":"68:52","surah":68,"ayah":52,"arabic":"وَمَا هُوَ إِلَّا ذِكْرٌ لِّلْعَالَمِي