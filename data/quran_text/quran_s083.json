ين","قلب","كسب","كون"],"tokens_ordered":["كلا","ران","قلوبهم","كانوا","يكسبون"],"vec_preview":[-0.05119999870657921,0.03550000116229057,-0.03660000115633011,-0.027699999511241913,0.06040000170469284,-0.0966000035405159,-0.017100000753998756,0.051500000059604645]},{"ayah_id":"83:15","surah":83,"ayah":15,"arabic":"كَلَّا إِنَّهُمْ عَن رَّبِّهِمْ يَوْمَئِذٍ لَّمَحْجُوبُونَ","english":"The truth is that they will be screened off (to deprive them of) the sight of their Lord.","roots_ordered":["حجب","ربب"],"tokens_ordered":["كلا","ربهم","يومءذ","لمحجوبون"],"vec_preview":[-0.093299999833107,0.05290000140666962,-0.07649999856948853,-0.02969999983906746,-0.015799999237060547,-0.028999999165534973,-0.04749999940395355,0.0714000016450882]},{"ayah_id":"83:16","surah":83,"ayah":16,"arabic":"ثُمَّ إِنَّهُمْ لَصَالُو الْجَحِيمِ","english":"Then they will be cast into Hell.","roots_ordered":["جحم","صلي"],"tokens_ordered":["لصالو","الجحيم"],"vec_preview":[-0.0272000003606081,0.009600000455975533,-0.024000000208616257,0.07840000092983246,0.024299999698996544,-0.09030000120401382,-0.028999999165534973,0.1307000070810318]},{"ayah_id":"83:17","surah":83,"ayah":17,"arabic":"ثُمَّ يُقَالُ هَـٰذَا الَّذِي كُنتُم بِهِ تُكَذِّبُونَ","english":"Then it will be said to them: ‘This is (the punishment of Hell) which you used to belie.’","roots_ordered":["ٱلذي","قول","كذب","كون"],"tokens_ordered":["يقال","الذي","كنتم","به","تكذبون"],"vec_preview":[0.018200000748038292,0.10689999908208847,-0.01889999955892563,0.0560000017285347,0.023499999195337296,-0.03909999877214432,-0.04639999940991402,0.09049999713897705]},{"ayah_id":"83:18","surah":83,"ayah":18,"arabic":"كَلَّا إِنَّ كِتَابَ الْأَبْرَارِ لَفِي عِلِّيِّينَ","english":"This is (also) true that the record of the truly pious is for sure maintained in ‘Illiyyin (the ante-chamber of Paradise).","roots_ordered":["برر","علو","كتب"],"tokens_ordered":["كلا","كتاب","الابرار","لفي","عليين"],"vec_preview":[-0.07919999957084656,-0.01759999990463257,-0.065